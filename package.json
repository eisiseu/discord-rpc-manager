{
  "name": "discord-rpc-manager",
  "version": "1.5.1",
  "description": "Discord Rich Presence Manager - Custom Activity Dashboard",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.0.1",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.discord.rpc-manager",
    "productName": "Discord RPC Manager",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ko-KR",
        "en-US",
        "ja-JP",
        "zh-CN"
      ],
      "language": "1042"
    },
    "publish": {
      "provider": "github",
      "owner": "eisiseu",
      "repo": "discord-rpc-manager"
    }
  }
}
